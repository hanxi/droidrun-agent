{
  "name": "droidrun-agent",
  "version": "0.1.1",
  "description": "Controls Android devices via DroidRun Portal. Supports tap, swipe, screenshot, text input, app management, UI state retrieval and more.",
  "transport": "stdio",
  "command": "uvx",
  "args": ["--with", "mcp", "droidrun-agent", "--mcp"],
  "config_schema": {
    "PORTAL_BASE_URL": {
      "type": "string",
      "required": true,
      "description": "Portal HTTP or WebSocket base URL, e.g. http://192.168.1.100:8080"
    },
    "PORTAL_TOKEN": {
      "type": "string",
      "required": true,
      "secret": true,
      "description": "Portal Bearer authentication token"
    },
    "PORTAL_TIMEOUT": {
      "type": "number",
      "default": 10.0,
      "description": "Request timeout in seconds"
    },
    "PORTAL_TRANSPORT": {
      "type": "string",
      "enum": ["http", "ws"],
      "default": "http",
      "description": "Transport type: http (port 8080) or ws (port 8081)"
    }
  }
}
